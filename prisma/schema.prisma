generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  location      String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]

  // Phase 10 platform-sync persistence (see models below). Additive only —
  // does not affect NextAuth's Account/Session relations above.
  platformAccounts PlatformAccount[]
  userGames        UserGame[]

  // Phase 11 gamification engine
  gamificationEvents GamificationEvent[]
  pointsLedger       PointsLedger[]
  userRuleStates     UserRuleState[]
  userBrandPoints    UserBrandPoints[]
  userBadges         UserBadge[]
  userStreaks        UserStreak[]

  // Phase 12 social graph + referrals
  inviteCodesIssued InviteCode[] @relation("InviterCodes")
  inviteCodeUsed    InviteCode?  @relation("InviteeCodes")
  following         UserFollow[] @relation("Following")
  followers         UserFollow[] @relation("Followers")
  reviews           GameReview[]
  gameLists         GameList[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===========================================================================
// Platform sync persistence (Phase 10)
//
// Persistence foundation for the normalized, platform-agnostic ingestion flow:
//
//   PlatformAccount -> PlatformSyncRun -> PlatformDetectedGame
//     -> GameExternalSource -> (canonical Game) -> UserGame
//     -> Discovery / Profile / Stats / Rankings
//
// Status fields are plain Strings (not Prisma enums) and MUST use the official
// vocabularies declared in lib/platforms/platforms.js so the DB and the JS
// constants never drift:
//
//   PlatformAccount.status      : connected | disconnected | needs_reauth | unavailable   (PLATFORM_ACCOUNT_STATUS)
//   *.syncStatus / run status   : idle | syncing | success | failed | partial             (PLATFORM_SYNC_STATUS)
//   PlatformSyncRun.mode        : dry_run | execute
//   PlatformDetectedGame.match  : matched | unmatched | ignored
//   GameExternalSource.status   : active | deprecated | review_required
//
// NOTE: This is a NEW model named PlatformAccount — it intentionally does NOT
// reuse NextAuth's `Account` model above. No runtime code reads or writes these
// models yet; this phase is schema + docs only.
// See docs/PLATFORM_SYNC_PERSISTENCE_MODEL.md.
// ===========================================================================

// A user's connected (or connectable) game-data platform account (Steam, PSN, …).
model PlatformAccount {
  id             String    @id @default(cuid())
  userId         String
  provider       String // "steam" | "psn" | future providers
  externalUserId String? // e.g. steamid64, PSN account id
  username       String?
  displayName    String?
  status         String    @default("disconnected") // PLATFORM_ACCOUNT_STATUS
  syncStatus     String    @default("idle") // PLATFORM_SYNC_STATUS
  connectedAt    DateTime?
  disconnectedAt DateTime?
  lastSyncAt     DateTime?
  needsReauthAt  DateTime?
  capabilities   Json? // snapshot of platform capabilities at connect time
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncRuns      PlatformSyncRun[]
  detectedGames PlatformDetectedGame[]

  // One account per user per provider.
  @@unique([userId, provider])
  @@index([provider])
  @@index([status])
  @@index([syncStatus])
}

// One sync attempt (or dry-run) against a platform account. Provides audit/history.
model PlatformSyncRun {
  id                    String    @id @default(cuid())
  platformAccountId     String
  provider              String
  mode                  String    @default("dry_run") // "dry_run" | "execute"
  status                String    @default("idle") // PLATFORM_SYNC_STATUS
  startedAt             DateTime?
  finishedAt            DateTime?
  rawGamesDetected      Int       @default(0)
  matchedCanonicalGames Int       @default(0)
  unmatchedGames        Int       @default(0)
  userGamesToCreate     Int       @default(0)
  userGamesToUpdate     Int       @default(0)
  warnings              Json?
  errorCode             String?
  errorMessage          String?
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  platformAccount PlatformAccount        @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
  detectedGames   PlatformDetectedGame[]

  @@index([platformAccountId])
  @@index([provider])
  @@index([status])
  @@index([startedAt])
}

// A normalized detected game from a platform account (raw + normalized snapshots
// kept for auditability). Resolved to a canonical game via GameExternalSource.
model PlatformDetectedGame {
  id                   String    @id @default(cuid())
  platformAccountId    String
  syncRunId            String?
  provider             String
  externalGameId       String // Steam appId / PSN titleId
  externalTitle        String?
  playtimeHours        Float?
  achievementsUnlocked Int?
  trophiesUnlocked     Int?
  lastPlayedAt         DateTime?
  canonicalGameId      String? // null until matched
  matchStatus          String    @default("unmatched") // "matched" | "unmatched" | "ignored"
  raw                  Json? // untrusted raw platform payload (audit)
  normalized           Json? // normalized Leet9 detected-game shape
  firstDetectedAt      DateTime  @default(now())
  lastDetectedAt       DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  platformAccount PlatformAccount  @relation(fields: [platformAccountId], references: [id], onDelete: Cascade)
  syncRun         PlatformSyncRun? @relation(fields: [syncRunId], references: [id], onDelete: SetNull)

  // Idempotency: a platform account reports each external game at most once.
  @@unique([platformAccountId, provider, externalGameId])
  @@index([provider])
  @@index([canonicalGameId])
  @@index([matchStatus])
}

// Maps a platform externalId to a canonical Leet9 game. The single source of
// truth for canonical matching; canonical game data is never duplicated here.
model GameExternalSource {
  id              String   @id @default(cuid())
  provider        String
  externalGameId  String
  externalTitle   String?
  canonicalGameId String // canonical Leet9 game id (String for now — no persisted Game model yet)
  confidence      String? // e.g. "high" | "medium" | "low"
  status          String   @default("active") // "active" | "deprecated" | "review_required"
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // One mapping per platform external game.
  @@unique([provider, externalGameId])
  @@index([canonicalGameId])
  @@index([status])
}

// A user's relationship to a canonical game (created/updated by real sync later).
model UserGame {
  id                      String    @id @default(cuid())
  userId                  String
  canonicalGameId         String
  sourceProvider          String? // which platform first contributed this game
  sourcePlatformAccountId String? // PlatformAccount.id reference (loose, not FK)
  firstDetectedAt         DateTime?
  lastDetectedAt          DateTime?
  playtimeHours           Float?
  achievementsUnlocked    Int?
  trophiesUnlocked        Int?
  sourceConfidence        String?
  metadata                Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A user has one record per canonical game (no duplicates).
  @@unique([userId, canonicalGameId])
  @@index([canonicalGameId])
  @@index([sourceProvider])
}

// ===========================================================================
// Gamification Engine (Phase 11)
//
// Tables:
//   GamificationRule    — config-driven rule definitions (mirrors spec)
//   GamificationEvent   — raw immutable event log
//   PointsLedger        — immutable points audit trail
//   UserRuleState       — per-user per-rule engine state (idempotency, caps)
//   UserBrandPoints     — running brand-family totals (drives badge unlocks)
//   UserBadge           — permanently unlocked badges
//   UserStreak          — login/play streak counters
//
// Event types (GamificationEvent.eventType / GamificationRule.eventType):
//   user_login | game_hours_daily | game_hours_weekly | social_connected |
//   achievement_unlocked | achievement_shared | game_added |
//   gaming_account_connected | web3_wallet_connected
// ===========================================================================

// Config-driven rule definitions — every row in the gamification spec maps
// to one row here. Changing point values, thresholds, or caps = DB update only.
model GamificationRule {
  id                    String    @id             // slug: "login_daily", "login_streak_7", …
  family                String                    // "user_retention" | "prerequisite" | "sharing" | "video_game" | …
  objective             String                    // "login_bonus" | "gamer_bonus_daily" | …
  type                  String                    // "activity" | "milestone"
  active                Boolean   @default(false)
  label                 String?                   // short UI display name e.g. "Daily Login"
  description           String                    // user-facing "why you earned this" explanation
  brandedName           String?                   // "Overachiever" | "Relentless" | …
  looped                Boolean   @default(false) // true = can fire more than once
  loopFrequency         String?                   // "daily" | "weekly" | null
  points                Int?                      // null = NA / not yet defined
  eventType             String                    // which event triggers this rule
  thresholdCount        Int?                      // milestone: cumulative count to reach
  badgeActive           Boolean   @default(false)
  badgeTier             String?                   // "bronze" | "silver" | "gold" | "tbd"
  badgeCollectionPoints Int?                      // brand-family points to unlock this tier
  badgeVisible          Boolean   @default(true)  // false = track but don't show yet
  yearlyMaxPoints       Int?                      // hard annual cap for this rule
  startsAt              DateTime?                 // seasonal events: rule inactive before this date
  endsAt                DateTime?                 // seasonal events: rule inactive after this date
  etaNote               String?                   // informational only, engine ignores
  metadata              Json?                     // rule-specific params (requiredHours, provider, field, …)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  ledgerEntries  PointsLedger[]
  userRuleStates UserRuleState[]

  @@index([eventType])
  @@index([active])
  @@index([brandedName])
}

// Raw event log — immutable, append-only. Every user action that could
// trigger a rule is written here first, then evaluated by the engine.
model GamificationEvent {
  id             String   @id @default(cuid())
  userId         String
  eventType      String
  occurredAt     DateTime @default(now())
  payload        Json                         // { hoursToday, provider, totalGames, … }
  idempotencyKey String   @unique             // prevents double-firing on retries

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries PointsLedger[]

  @@index([userId])
  @@index([eventType])
  @@index([occurredAt])
}

// Immutable points audit trail — one row per award. Never update, never delete.
// Sum of points per userId = user's current balance.
model PointsLedger {
  id        String   @id @default(cuid())
  userId    String
  ruleId    String
  eventId   String?                           // null = manual / admin adjustment
  points    Int                               // always positive
  awardedAt DateTime @default(now())
  note      String?

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule  GamificationRule   @relation(fields: [ruleId], references: [id])
  event GamificationEvent? @relation(fields: [eventId], references: [id])

  @@index([userId])
  @@index([ruleId])
  @@index([awardedAt])
}

// Per-user per-rule engine state. Tracks idempotency, yearly cap progress,
// and last-fired timestamps for looped rules.
model UserRuleState {
  id               String    @id @default(cuid())
  userId           String
  ruleId           String
  firedCount       Int       @default(0)     // total times this rule fired for this user
  pointsThisYear   Int       @default(0)     // toward yearlyMaxPoints
  yearResetAt      DateTime?                 // when the yearly counter was last reset
  lastFiredAt      DateTime?                 // for looped rules: last fire time
  milestoneReached Boolean   @default(false) // for one-time milestones: already fired?
  updatedAt        DateTime  @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule GamificationRule @relation(fields: [ruleId], references: [id])

  @@unique([userId, ruleId])
  @@index([userId])
}

// Running total of points earned per branded-name family per user.
// Updated atomically alongside PointsLedger; drives badge tier checks.
model UserBrandPoints {
  id          String   @id @default(cuid())
  userId      String
  brandedName String
  totalPoints Int      @default(0)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brandedName])
  @@index([userId])
}

// Permanently unlocked badges — never revoked. One row per tier per brand.
model UserBadge {
  id             String   @id @default(cuid())
  userId         String
  brandedName    String
  tier           String                       // "bronze" | "silver" | "gold"
  unlockedAt     DateTime @default(now())
  pointsSnapshot Int                          // brand points at unlock time (audit)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brandedName, tier])
  @@index([userId])
}

// Login and play streak counters. Streak breaks when a day/week is missed.
model UserStreak {
  id               String    @id @default(cuid())
  userId           String
  streakType       String                     // "login_daily" | "play_weekly"
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?                  // date-only; used to detect streak continuity
  streakStartedAt  DateTime?
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, streakType])
  @@index([userId])
}

// ===========================================================================
// Phase 12 — Social graph, referrals, content creation
// ===========================================================================

// Referral invite codes. One code per use; inviter earns points when invitee activates.
model InviteCode {
  id        String    @id @default(cuid())
  code      String    @unique
  inviterId String
  inviteeId String?   @unique               // null until someone uses the code
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  inviter User  @relation("InviterCodes", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User? @relation("InviteeCodes", fields: [inviteeId], references: [id], onDelete: SetNull)

  @@index([inviterId])
  @@index([code])
}

// Directed follow graph — follower follows following.
model UserFollow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// User-written game reviews. One review per user per game.
model GameReview {
  id        String   @id @default(cuid())
  userId    String
  gameId    String                          // canonical game id
  rating    Int                             // 1–10
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId])
}

// User-curated game lists (e.g. "My Top 10 RPGs").
model GameList {
  id        String         @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items GameListItem[]

  @@index([userId])
}

model GameListItem {
  id        String   @id @default(cuid())
  listId    String
  gameId    String
  rank      Int
  createdAt DateTime @default(now())

  list GameList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, gameId])
  @@unique([listId, rank])
  @@index([listId])
}
